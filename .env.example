# ---- LLM (required) ----
ANTHROPIC_API_KEY=sk-ant-...
# Model used for high-volume pre-scoring (cheap).
# Prefix with `local:` or `ollama:` to route scoring to your own machine for FREE,
# e.g. MODEL_PREFILTER=local:llama3.1  (keep MODEL_GENERATION on a hosted model —
# the agent + cover letters want the reliability).
MODEL_PREFILTER=claude-haiku-4-5-20251001
# Model used for finalist scoring + all generation (strong).
# Prefix with `claude-cli:` (e.g. claude-cli:sonnet) to shell out to a logged-in
# Claude Code CLI in headless mode — bills the Claude subscription instead of the API,
# so no ANTHROPIC_API_KEY is required.
MODEL_GENERATION=claude-sonnet-5

# ---- Local / OpenAI-compatible model runtime (only used for `local:`/`ollama:` ids) ----
# Ollama default below; LM Studio = http://localhost:1234/v1 ; vLLM = your host.
# Comma-separate multiple endpoints to pool them (round-robin + failover) —
# every endpoint must have the model you reference pulled.
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# Jobs scored simultaneously (default 2). Match this to your endpoint count
# so every machine in the pool stays busy.
SCORING_CONCURRENCY=2
LOCAL_LLM_API_KEY=ollama

# ---- Storage ----
DATABASE_PATH=./data/app.sqlite
ARTIFACTS_DIR=./artifacts

# ---- Server (n8n calls these endpoints) ----
PORT=8787
# Base URL used in approve/reject links sent to you (LAN IP or public URL of
# this worker). Defaults to http://localhost:PORT — links then only work on
# the server itself.
PUBLIC_BASE_URL=
# Shared secret n8n includes as `x-webhook-secret` header
WEBHOOK_SECRET=change-me

# ---- Approval / notifications (n8n owns delivery; these are fallbacks) ----
# Base URL n8n exposes for approve/reject webhooks
N8N_APPROVAL_WEBHOOK=http://localhost:5678/webhook/approval

# ---- Browser automation ----
# One of: kernel-cloud | kernel-selfhost | local
BROWSER_PROVIDER=local
# kernel-cloud only:
KERNEL_API_KEY=
# kernel-selfhost only: CDP endpoint exposed by the kernel-images docker container
KERNEL_CDP_URL=http://localhost:9222
# kernel-selfhost live view (noVNC/WebRTC) for human takeover
KERNEL_LIVE_VIEW_URL=http://localhost:8080
# kernel-cloud tuning:
# stealth folds in Kernel's anti-bot + CAPTCHA handling; the live-view handoff still
# backstops it. Set false to run plain + rely only on our detect-and-hand-off flow.
KERNEL_STEALTH=true
# Optional Kernel saved-profile id for persistent logins (e.g. LinkedIn/Indeed)
KERNEL_PROFILE_ID=
# Remote session inactivity timeout, seconds. Live-view/CDP connections reset it.
# Max 259200 (72h) if you want a job to sit parked awaiting your approval.
KERNEL_TIMEOUT_SECONDS=300

# ---- Safety switches ----
# Master kill-switch: when true, never actually submits (dry run everything)
DRY_RUN=true
# Sources that violate ToS are off unless explicitly enabled
ENABLE_LINKEDIN=false
ENABLE_INDEED=false
# Max applications submitted per rolling 24h (politeness / rate limit)
MAX_SUBMISSIONS_PER_DAY=15

# ---- Agentic submission (unknown/custom ATS like Phenom, iCIMS, bespoke portals) ----
# When true, unknown ATS pages are driven by an AI browser-agent loop instead of a
# hardcoded filler. Set false to fall back to the generic DOM walker.
AGENTIC_FALLBACK=true
# Hard cap on agent tool-steps per application (bounds cost + runaway loops).
AGENTIC_MAX_STEPS=25
