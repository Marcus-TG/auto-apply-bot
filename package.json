{
  "name": "auto-apply-bot",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered job discovery, fit scoring, resume/cover-letter tailoring, and human-gated application submission.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/server.ts",
    "server": "tsx src/server.ts",
    "discover": "tsx src/cli.ts discover",
    "pipeline": "tsx src/cli.ts run",
    "db:init": "tsx src/cli.ts db:init"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@onkernel/sdk": "^0.74.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "playwright": "^1.49.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
